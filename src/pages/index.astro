---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Samantha Ritter & Daniel Brykalov">
  <section class="hero">
    <div class="hero-content">
      <div class="eyebrow">OFFICIAL WEBSITE</div>

      <h1 class="hero-title">
        <span>Samantha Ritter</span>
        <span>& Daniel Brykalov</span>
      </h1>

      <p class="hero-subtitle">
        International Ice Dance Team Representing Azerbaijan
      </p>

      <img
        class="hero-skaters hero-skaters-mobile"
        src="/images/hero-skaters-cutout.png"
        alt="Samantha Ritter and Daniel Brykalov performing on ice"
      />

      <div class="hero-buttons">
        <a href="/journey" class="btn btn-gold">Our Journey</a>
        <a href="/results" class="btn btn-ice">Results</a>
      </div>
    </div>

    <img
      class="hero-skaters hero-skaters-desktop"
      src="/images/hero-skaters-cutout.png"
      alt="Samantha Ritter and Daniel Brykalov performing on ice"
    />
  </section>
</MainLayout>

<style is:global>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 100vh;
    max-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    background-image: url("/images/hero-bg.png");
    background-size: 100% 100%;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(2, 10, 22, 0.34) 0%,
      rgba(2, 10, 22, 0.18) 42%,
      rgba(2, 10, 22, 0.02) 100%
    );
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    width: min(100% - 2rem, 1280px);
    margin-inline: auto;
    padding-top: 72px;
    transform: translateY(-1rem);
  }

  .eyebrow {
    color: #f3d46b;
    font-size: 0.86rem;
    letter-spacing: 0.28em;
    font-weight: 900;
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-size: clamp(2.4rem, 3vw, 4rem);
    line-height: 0.96;
    font-weight: 900;
    letter-spacing: -0.045em;
    margin-bottom: 1.45rem;
    max-width: 620px;
    background: linear-gradient(180deg, #fff8d8 0%, #ffe27a 45%, #d6a832 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow:
      0 1px 0 rgba(255,255,255,0.25),
      0 3px 0 rgba(122,86,10,0.35),
      0 8px 16px rgba(0,0,0,0.26);
  }

  .hero-title span {
    display: block;
    white-space: nowrap;
  }

  .hero-subtitle {
    font-size: 1.18rem;
    color: rgba(255,255,255,0.94);
    max-width: 650px;
    margin-bottom: 2.4rem;
    text-shadow: 0 3px 14px rgba(0,0,0,0.35);
  }

  .hero-buttons {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 15px 32px;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .btn-gold {
    background: linear-gradient(180deg, #fff1b8 0%, #f2cd5a 45%, #c9942e 100%);
    color: #10213d;
    border: 1px solid rgba(255,255,255,0.25);
    box-shadow: 0 3px 0 #8c6713, 0 12px 24px rgba(0,0,0,.25);
  }

  .btn-gold:hover {
    background: linear-gradient(180deg, #fff8d8 0%, #ffe27a 45%, #d6a832 100%);
    transform: translateY(-2px);
  }

  .btn-ice {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.34);
    color: white;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.10),
      0 8px 20px rgba(0,0,0,0.15);
    backdrop-filter: blur(8px);
  }

  .btn-ice:hover {
    background: rgba(255,255,255,0.16);
    border-color: rgba(243,212,107,0.85);
    transform: translateY(-2px);
  }

  .hero-skaters {
    width: auto;
    object-fit: contain;
    filter:
      drop-shadow(0 0 5px rgba(220,235,255,0.16))
      drop-shadow(0 0 14px rgba(220,235,255,0.10))
      drop-shadow(0 30px 44px rgba(0,0,0,0.42));
  }

  .hero-skaters-mobile {
    display: none;
  }

  .hero-skaters-desktop {
    display: block;
    position: absolute;
    z-index: 2;
    right: clamp(8rem, 30vw, 32rem);
    bottom: 2rem;
    height: min(84svh, 860px);
    max-width: 48vw;
  }

  @media (max-width: 950px) {
    .hero {
      height: 100svh;
      min-height: 100svh;
      max-height: none;
      align-items: flex-start;
      padding: 7.5rem 0 2rem;
      background-size: cover;
      background-position: 62% center;
    }

    .hero-content {
      width: min(100% - 1.75rem, 520px);
      padding-top: 0;
      transform: none;
      margin-inline: auto;
    }

    .hero-skaters-desktop {
      display: none;
    }

    .hero-skaters-mobile {
      display: block;
      position: relative;
      height: min(39vh, 370px);
      max-width: 88vw;
      margin: 1.15rem auto 1.35rem;
      opacity: 0.96;
    }

    .eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.24em;
      margin-bottom: 0.8rem;
    }

    .hero-title {
      font-size: clamp(2rem, 8vw, 2.85rem);
      line-height: 0.98;
      max-width: 100%;
      margin-bottom: 0.85rem;
    }

    .hero-subtitle {
      font-size: 1rem;
      line-height: 1.45;
      max-width: 23rem;
      margin-bottom: 0;
    }

    .hero-buttons {
      gap: 1rem;
    }

    .btn {
      padding: 13px 24px;
    }
  }

  @media (max-width: 430px) {
    .hero {
      padding-top: 7.25rem;
    }

    .hero-skaters-mobile {
      height: min(37vh, 350px);
      max-width: 88vw;
      margin: 1rem auto 1.25rem;
    }

    .hero-title {
      font-size: clamp(1.85rem, 8vw, 2.45rem);
    }

    .hero-subtitle {
      font-size: 0.95rem;
      max-width: 20rem;
    }

    .btn {
      padding: 12px 22px;
    }
  }
</style>